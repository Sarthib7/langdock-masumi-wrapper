PORT=3000

# Langdock (server-side only — never expose to the browser)
LANGDOCK_API_KEY=
LANGDOCK_AGENT_ID=
LANGDOCK_BASE_URL=https://api.langdock.com

# Masumi / registry identity (echoed in /start_job; optional placeholder if unset)
AGENT_IDENTIFIER=
SELLER_VKEY=

# Unix offsets (seconds) for payment window fields on /start_job
PAY_BY_OFFSET_SEC=3600
SUBMIT_RESULT_OFFSET_SEC=1800
UNLOCK_OFFSET_SEC=2700
EXTERNAL_DISPUTE_UNLOCK_OFFSET_SEC=3600
