PORT=3000

# ---- Langdock (server-side only — never expose to the browser) ----
LANGDOCK_API_KEY=
LANGDOCK_AGENT_ID=
LANGDOCK_BASE_URL=https://api.langdock.com

# ---- Masumi agent identity (returned by /start_job) ----
# Obtain AGENT_IDENTIFIER by registering your agent on the Masumi Payment Service.
# SELLER_VKEY is the selling wallet's verification key (from the admin dashboard).
AGENT_IDENTIFIER=
SELLER_VKEY=

# ---- Payment mode ----
# "masumi" -> requires Masumi SaaS or a running Masumi Payment Service node.
# "direct" -> skip escrow, run the handler synchronously (local dev only).
# If unset, defaults to "masumi" when PAYMENT_SERVICE_URL is provided,
# otherwise "direct".
PAYMENT_MODE=

# Set true in staging if you want startup to fail until every production
# credential below is present. Production Docker images also enforce this via NODE_ENV.
REQUIRE_PRODUCTION_CONFIG=false

# Optional shared token required by POST /setup/config.
# Set this before exposing the hosted setup page outside localhost.
SETUP_ACCESS_TOKEN=
# Optional override for where the setup UI persists submitted config.
# Defaults to .env in the current working directory.
SETUP_ENV_PATH=

# ---- Masumi SaaS / Payment Service (required when PAYMENT_MODE=masumi) ----
# Must include the API prefix:
# Masumi SaaS API:      PAYMENT_SERVICE_URL=https://<saas-host>/pay/api/v1
# Direct payment node:  PAYMENT_SERVICE_URL=https://<payment-node-host>/api/v1
PAYMENT_SERVICE_URL=
PAYMENT_API_KEY=
NETWORK=Preprod
# Auto-detects "x-api-key" when PAYMENT_SERVICE_URL contains /pay/api/v1;
# otherwise defaults to "token". Set explicitly if needed.
PAYMENT_API_AUTH_HEADER=
PAYMENT_POLL_INTERVAL_MS=5000
PAYMENT_POLL_TIMEOUT_MS=1800000

# ---- Optional dynamic pricing override ----
# Leave empty for normal fixed pricing configured on the registered Masumi agent.
# If set, this is sent as Payment API RequestedFunds.
# Sokosumi requires USDCx/tUSDM settlement with 6 decimals.
# Do not use "lovelace" here for tUSDM/USDCx. Lovelace is ADA's smallest unit
# for fees/min-UTXO ADA; stablecoin pricing uses the token asset id below.
# Preprod tUSDM unit:
# 16a55b2a349361ff88c03788f93e1e966e5d689605d044fef722ddde0014df10745553444d
# Mainnet USDM unit:
# c48cbb3d5e57ed56e276bc45f99ab39abe94e6cd7ac39fb402da47ad0014df105553444d
PRICE_AMOUNTS=

# ---- Optional setup UI registry metadata ----
REGISTRY_AGENT_NAME=
REGISTRY_AGENT_DESCRIPTION=
REGISTRY_AGENT_API_BASE_URL=
REGISTRY_CAPABILITY_NAME=langdock-agent
REGISTRY_CAPABILITY_VERSION=1.0.0
REGISTRY_AUTHOR_NAME=
REGISTRY_AUTHOR_CONTACT_EMAIL=
REGISTRY_AUTHOR_CONTACT_OTHER=
REGISTRY_AUTHOR_ORGANIZATION=
REGISTRY_TAGS=langdock,masumi
REGISTRY_PRICING_AMOUNT=1000000
REGISTRY_PRICING_UNIT=
REGISTRY_LEGAL_PRIVACY_POLICY=
REGISTRY_LEGAL_TERMS=
REGISTRY_LEGAL_OTHER=

# ---- Payment windows (Unix seconds, monotonic, min 5 min gap to submitResult) ----
PAY_BY_OFFSET_SEC=900
SUBMIT_RESULT_OFFSET_SEC=2700
UNLOCK_OFFSET_SEC=3600
EXTERNAL_DISPUTE_UNLOCK_OFFSET_SEC=5400

# ---- /input_schema payload ----
# Either point at a JSON file or provide an inline JSON array of MIP-003 schema fields.
INPUT_SCHEMA_PATH=
INPUT_SCHEMA_JSON=
